---
import "../styles/global.css";
import Navbar from "../components/navbar.astro";
import Footer from "../components/footer.astro";
const { title = "Portfolio Adrián Aguilar" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{title}</title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css">
    </head>

    <body style={`background-image: url('${import.meta.env.BASE_URL}wl3.png');`} class="bg-cover bg-center md:bg-fixed scroll-smooth min-h-screen flex flex-col">
        <Navbar />
        
        <main class="grow w-full max-w-5xl mx-auto p-6">
            <slot />
        </main>
        
        <Footer />

        <script>
            import "../scripts/global.js";
        </script>
    </body>
</html>